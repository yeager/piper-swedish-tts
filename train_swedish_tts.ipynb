   "source": [
    "# 🇸🇪 Swedish Piper TTS Training\n",
    "\n",
    "Train a high-quality Swedish text-to-speech voice using:\n",
    "- **Piper** (VITS architecture)\n",
    "- **NST Swedish TTS dataset** (5300 recordings, CC0)\n",
    "- **KBLab's pretrained checkpoint** (epoch 4041)\n",
    "\n",
    "## Setup\n",
    "1. Runtime → Change runtime type → **T4 GPU**\n",
    "2. Run all cells\n",
    "3. Training takes ~8-12h on T4\n",
    "4. Model auto-saves to Google Drive"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "#@title 1. Mount Google Drive (for saving checkpoints)\n",
    "from google.colab import drive\n",
    "drive.mount('/content/drive')\n",
    "\n",
    "import os\n",
    "SAVE_DIR = '/content/drive/MyDrive/piper-swedish-tts'\n",
    "os.makedirs(SAVE_DIR, exist_ok=True)\n",
    "print(f'✅ Save directory: {SAVE_DIR}')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "#@title 2. Install Piper Training Dependencies\n",
    "%%bash\n",
    "set -e\n",
    "\n",
    "# Clone piper with training code\n",
    "if [ ! -d /content/piper ]; then\n",
    "  git clone --depth 1 https://github.com/rhasspy/piper.git /content/piper\n",
    "fi\n",
    "\n",
    "cd /content/piper/src/python\n",
    "pip install -e . 2>&1 | tail -5\n",
    "\n",
    "# Install piper-phonemize\n",
    "pip install piper-phonemize 2>&1 | tail -3\n",
    "\n",
    "# Verify GPU\n",
    "python3 -c \"import torch; print(f'GPU: {torch.cuda.get_device_name(0)}'); print(f'VRAM: {torch.cuda.get_device_properties(0).total_mem / 1e9:.1f} GB')\"\n",
    "\n",
    "echo '✅ Dependencies installed'"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "#@title 3. Download NST Swedish TTS Dataset\n",
    "%%bash\n",
    "set -e\n",
    "\n",
    "if [ ! -d /content/nst_data ]; then\n",
    "  echo 'Downloading NST Swedish dataset from HuggingFace...'\n",
    "  pip install -q datasets soundfile\n",
    "  python3 << 'EOF'\n",
    "import os\n",
    "import json\n",
    "import soundfile as sf\n",
    "from datasets import load_dataset\n",
    "\n",
    "# Load NST dataset\n",
    "print('Loading dataset...')\n",
    "ds = load_dataset('jimregan/nst_swedish_tts', split='train')\n",
    "print(f'Total samples: {len(ds)}')\n",
    "\n",
    "# Create output dirs\n",
    "out_dir = '/content/nst_data'\n",
    "wav_dir = os.path.join(out_dir, 'wav')\n",
    "os.makedirs(wav_dir, exist_ok=True)\n",
    "\n",
    "# Process and save\n",
    "metadata = []\n",
    "for i, sample in enumerate(ds):\n",
    "    audio = sample['audio']\n",
    "    text = sample.get('text', sample.get('sentence', ''))\n",
    "    if not text or not audio:\n",
    "        continue\n",
    "    \n",
    "    wav_path = os.path.join(wav_dir, f'{i:06d}.wav')\n",
    "    sf.write(wav_path, audio['array'], audio['sampling_rate'])\n",
    "    metadata.append({'file': f'wav/{i:06d}.wav', 'text': text})\n",
    "    \n",
    "    if i % 500 == 0:\n",
    "        print(f'  Processed {i}/{len(ds)}')\n",
    "\n",
    "# Save metadata\n",
    "with open(os.path.join(out_dir, 'metadata.json'), 'w') as f:\n",
    "    json.dump(metadata, f, ensure_ascii=False, indent=2)\n",
    "\n",
    "# Also create LJSpeech-style metadata.csv\n",
    "with open(os.path.join(out_dir, 'metadata.csv'), 'w') as f:\n",
    "    for m in metadata:\n",
    "        basename = os.path.splitext(os.path.basename(m['file']))[0]\n",
    "        f.write(f\"{basename}|{m['text']}|{m['text']}\\n\")\n",
    "\n",
    "print(f'\\n✅ Saved {len(metadata)} samples to {out_dir}')\n",
    "EOF\n",
    "else\n",
    "  echo '✅ NST data already downloaded'\n",
    "fi\n",
    "\n",
    "echo \"Files: $(ls /content/nst_data/wav/ | wc -l) wav files\""
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "#@title 4. Download KBLab Pretrained Checkpoint\n",
    "%%bash\n",
    "set -e\n",
    "\n",
    "CKPT_DIR=/content/pretrained\n",
    "mkdir -p $CKPT_DIR\n",
    "\n",
    "if [ ! -f $CKPT_DIR/epoch=4041-step=1753548.ckpt ]; then\n",
    "  echo 'Downloading KBLab checkpoint (846MB)...'\n",
    "  pip install -q huggingface_hub\n",
    "  python3 << 'EOF'\n",
    "from huggingface_hub import hf_hub_download\n",
    "import shutil\n",
    "\n",
    "# Download checkpoint\n",
    "ckpt = hf_hub_download(\n",
    "    repo_id='KBLab/piper-tts-nst-swedish',\n",
    "    filename='epoch=4041-step=1753548.ckpt',\n",
    "    local_dir='/content/pretrained'\n",
    ")\n",
    "print(f'✅ Checkpoint: {ckpt}')\n",
    "\n",
    "# Download config\n",
    "cfg = hf_hub_download(\n",
    "    repo_id='KBLab/piper-tts-nst-swedish',\n",
    "    filename='config.json',\n",
    "    local_dir='/content/pretrained'\n",
    ")\n",
    "print(f'✅ Config: {cfg}')\n",
    "EOF\n",
    "else\n",
    "  echo '✅ Checkpoint already downloaded'\n",
    "fi\n",
    "\n",
    "ls -lh $CKPT_DIR/"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "#@title 5. Preprocess Dataset for Piper\n",
    "%%bash\n",
    "set -e\n",
    "\n",
    "cd /content/piper/src/python\n",
    "\n",
    "# Preprocess: phonemize text, compute mel spectrograms\n",
    "if [ ! -d /content/training_data ]; then\n",
    "  echo 'Preprocessing dataset...'\n",
    "  python3 -m piper_train.preprocess \\\n",
    "    --language sv \\\n",
    "    --input-dir /content/nst_data \\\n",
    "    --output-dir /content/training_data \\\n",
    "    --dataset-format ljspeech \\\n",
    "    --single-speaker \\\n",
    "    --sample-rate 22050\n",
    "  echo '✅ Preprocessing complete'\n",
    "else\n",
    "  echo '✅ Training data already preprocessed'\n",
    "fi\n",
    "\n",
    "echo \"Training files:\"\n",
    "ls /content/training_data/ | head -10"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "#@title 6. 🚀 Start Training (Continue from KBLab checkpoint)\n",
    "#@markdown This will continue training from epoch 4041.\n",
    "#@markdown On T4 GPU, expect ~1000 steps/hour.\n",
    "#@markdown Target: 500k-1M additional steps for noticeable improvement.\n",
    "\n",
    "MAX_EPOCHS = 10000  #@param {type:\"integer\"}\n",
    "BATCH_SIZE = 16  #@param {type:\"integer\"}\n",
    "LEARNING_RATE = 1e-4  #@param {type:\"number\"}\n",
    "CHECKPOINT_EPOCHS = 100  #@param {type:\"integer\"}\n",
    "\n",
    "import subprocess\n",
    "import os\n",
    "\n",
    "# Training command\n",
    "cmd = [\n",
    "    'python3', '-m', 'piper_train',\n",
    "    '--dataset-dir', '/content/training_data',\n",
    "    '--accelerator', 'gpu',\n",
    "    '--devices', '1',\n",
    "    '--batch-size', str(BATCH_SIZE),\n",
    "    '--validation-split', '0.01',\n",
    "    '--max-epochs', str(MAX_EPOCHS),\n",
    "    '--resume_from_checkpoint', '/content/pretrained/epoch=4041-step=1753548.ckpt',\n",
    "    '--checkpoint-epochs', str(CHECKPOINT_EPOCHS),\n",
    "    '--precision', '32',\n",
    "    '--quality', 'medium',\n",
    "    '--default_root_dir', '/content/drive/MyDrive/piper-swedish-tts',\n",
    "]\n",
    "\n",
    "print('🚀 Starting training...')\n",
    "print(f'   Batch size: {BATCH_SIZE}')\n",
    "print(f'   Max epochs: {MAX_EPOCHS}')\n",
    "print(f'   Saving to: /content/drive/MyDrive/piper-swedish-tts')\n",
    "print(f'   Checkpoint every {CHECKPOINT_EPOCHS} epochs')\n",
    "print()\n",
    "\n",
    "os.chdir('/content/piper/src/python')\n",
    "process = subprocess.Popen(\n",
    "    cmd,\n",
    "    stdout=subprocess.PIPE,\n",
    "    stderr=subprocess.STDOUT,\n",
    "    text=True,\n",
    "    bufsize=1\n",
    ")\n",
    "\n",
    "for line in process.stdout:\n",
    "    print(line, end='')\n",
    "\n",
    "process.wait()\n",
    "print(f'\\n Training finished with code {process.returncode}')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "#@title 7. Export to ONNX (for Piper WASM)\n",
    "#@markdown Run this after training is complete (or to test a checkpoint).\n",
    "#@markdown The exported .onnx file can be used directly in autismapps.\n",
    "\n",
    "%%bash\n",
    "set -e\n",
    "\n",
    "cd /content/piper/src/python\n",
    "\n",
    "# Find the latest checkpoint\n",
    "CKPT=$(ls -t /content/drive/MyDrive/piper-swedish-tts/lightning_logs/*/checkpoints/*.ckpt 2>/dev/null | head -1)\n",
    "if [ -z \"$CKPT\" ]; then\n",
    "  echo '⚠️ No checkpoint found in Drive. Using pretrained...'\n",
    "  CKPT=/content/pretrained/epoch=4041-step=1753548.ckpt\n",
    "fi\n",
    "\n",
    "echo \"Exporting: $CKPT\"\n",
    "\n",
    "OUTPUT_DIR=/content/exported_model\n",
    "mkdir -p $OUTPUT_DIR\n",
    "\n",
    "python3 -m piper_train.export_onnx \\\n",
    "  \"$CKPT\" \\\n",
    "  \"$OUTPUT_DIR/sv_SE-nst-medium.onnx\"\n",
    "\n",
    "# Copy config alongside\n",
    "cp /content/pretrained/config.json $OUTPUT_DIR/sv_SE-nst-medium.onnx.json\n",
    "\n",
    "echo ''\n",
    "echo '✅ Exported model:'\n",
    "ls -lh $OUTPUT_DIR/\n",
    "\n",
    "# Also copy to Drive\n",
    "cp $OUTPUT_DIR/* /content/drive/MyDrive/piper-swedish-tts/\n",
    "echo '✅ Copied to Google Drive'"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
