   "source": [
    "#@title 8. Test the Model 🔊\n",
    "#@markdown Generate a sample to hear the quality.\n",
    "\n",
    "TEST_TEXT = \"Hej! Jag heter Alma och jag hjälper dig med dina övningar.\"  #@param {type:\"string\"}\n",
    "\n",
    "%%bash -s \"$TEST_TEXT\"\n",
    "set -e\n",
    "\n",
    "# Install piper for inference\n",
    "pip install -q piper-tts\n",
    "\n",
    "MODEL=/content/exported_model/sv_SE-nst-medium.onnx\n",
    "if [ ! -f \"$MODEL\" ]; then\n",
    "  echo '⚠️ Export the model first (step 7)'\n",
    "  exit 1\n",
    "fi\n",
    "\n",
    "echo \"$1\" | piper \\\n",
    "  --model \"$MODEL\" \\\n",
    "  --output_file /content/test_output.wav\n",
    "\n",
    "echo '✅ Generated: test_output.wav'\n",
    "echo 'Click the play button below to listen'"
   ],
